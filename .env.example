# Starknet (API renderer + frontend)
STARKNET_RPC_PRIMARY=
STARKNET_RPC_FALLBACK=
# Alias accepted by frontend env helper:
STARKNET_RPC_URL=
KOJI_COMPOSER_ADDRESS=

# Public base URL for NFT metadata uri (Solana mint + `external_url` in JSON)
RENDERER_BASE_URL=http://localhost:3000
NEXT_PUBLIC_RENDERER_BASE_URL=http://localhost:3000

# Solana
SOLANA_RPC_URL=
KOJI_RECEIVER_PROGRAM_ID=
# Relayer CLI (`relayer/`) — same program id as deploy
KOJI_PROGRAM_ID=
RELAYER_KEYPAIR=
KOJI_BRIDGE_ADDRESS=
RELAYER_POLL_MS=8000
RELAYER_CHUNK_SIZE=20
RELAYER_START_BLOCK=
RELAYER_MAX_RETRIES=3
RELAYER_STATE_PATH=.relay-state.json
RELAYER_DRY_RUN=0
